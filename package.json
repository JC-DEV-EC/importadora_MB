{
  "name": "importadora-mb",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "docker compose up backend --build",
    "dev:web": "npm run dev --prefix frontend",
    "build:web": "npm run build --prefix frontend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
